generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String?  @unique
  name      String?
  avatarUrl String?
  profile   UserProfile?
  sessions  Session[]
  moods     MoodEntry[]
  chats     ChatMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  onboardingGoal    String?
  timezone          String?
  dailyReminderEnabled Boolean  @default(false)
  dailyReminderTime    String?
  privacyAcceptedAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario  String
  details   String[]
  activityTags String[] @default([])
  level     String
  text      String?
  result    Json
  createdAt DateTime @default(now())
}

model MoodEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood      String
  rating    Int
  period    String?
  note      String?
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  content   String
  attachments Json?
  source    String?
  createdAt DateTime @default(now())
}
