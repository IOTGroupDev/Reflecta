generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String?  @unique
  name      String?
  sessions  Session[]
  moods     MoodEntry[]
  chats     ChatMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  scenario  String
  details   String[]
  level     String
  text      String?
  result    Json
  createdAt DateTime @default(now())
}

model MoodEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  mood      String
  rating    Int
  note      String?
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  role      String
  content   String
  source    String?
  createdAt DateTime @default(now())
}
